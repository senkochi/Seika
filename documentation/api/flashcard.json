{
  "openapi": "3.1.0",
  "info": {
    "title": "Flashcard Service API",
    "description": "Flashcard and CardSet management service for Seika platform",
    "contact": {
      "name": "Seika Development Team",
      "url": "https://seika.dev"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "API Gateway"
    },
    {
      "url": "http://flashcard-service:8086",
      "description": "Flashcard Service"
    }
  ],
  "paths": {
    "/api/flashcards": {
      "post": {
        "tags": ["card-set-controller"],
        "summary": "Create a new flashcard set (Teacher only)",
        "operationId": "createCardSet",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CardSetCreateRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CardSetResponse" }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["card-set-controller"],
        "summary": "Get all public flashcard sets (marketplace)",
        "operationId": "getAllCardSets",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CardSetResponse" }
                }
              }
            }
          }
        }
      }
    },
    "/api/flashcards/{id}": {
      "get": {
        "tags": ["card-set-controller"],
        "summary": "Get flashcard set by ID",
        "operationId": "getCardSetById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CardSetResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["card-set-controller"],
        "summary": "Delete a flashcard set (Teacher – owner only)",
        "operationId": "deleteCardSet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted successfully",
            "content": {
              "*/*": {
                "schema": { "type": "string" }
              }
            }
          },
          "403": {
            "description": "Forbidden – not the owner"
          },
          "404": {
            "description": "Card set not found"
          }
        }
      }
    },
    "/api/flashcards/author/{userId}": {
      "get": {
        "tags": ["card-set-controller"],
        "summary": "Get flashcard sets by author userId",
        "operationId": "getCardSetsByAuthor",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CardSetResponse" }
                }
              }
            }
          }
        }
      }
    },
    "/api/flashcards/search": {
      "get": {
        "tags": ["card-set-controller"],
        "summary": "Search flashcard sets by keyword",
        "operationId": "searchCardSets",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CardSetResponse" }
                }
              }
            }
          }
        }
      }
    },
    "/api/flashcards/buy": {
      "post": {
        "tags": ["card-set-controller"],
        "summary": "Purchase a flashcard set using Coins (Student)",
        "operationId": "buyCardSet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Purchase successful",
            "content": {
              "*/*": { "schema": { "type": "string" } }
            }
          }
        }
      }
    },
    "/api/flashcards/learn": {
      "post": {
        "tags": ["card-set-controller"],
        "summary": "Record a learning progress event (async via RabbitMQ)",
        "operationId": "sendLearnProgress",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LearnProgressRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Progress acknowledged"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Card": {
        "type": "object",
        "properties": {
          "front": { "type": "string" },
          "back": { "type": "string" }
        },
        "required": ["front", "back"]
      },
      "CardSetCreateRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "price": { "type": "integer", "format": "int32", "minimum": 0 },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          }
        },
        "required": ["title", "cards"]
      },
      "CardSetResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "integer", "format": "int32" },
          "authorId": { "type": "string" },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "LearnProgressRequest": {
        "type": "object",
        "properties": {
          "cardSetId": { "type": "string" },
          "userId": { "type": "string" },
          "cardsReviewed": { "type": "integer", "format": "int32" }
        },
        "required": ["cardSetId", "userId"]
      }
    }
  }
}
