{
  "openapi": "3.1.0",
  "info": {
    "title": "Profile Service API",
    "description": "User profile management service for Seika platform",
    "contact": {
      "name": "Seika Development Team",
      "url": "https://seika.dev"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "API Gateway"
    },
    {
      "url": "http://profile-service:8082",
      "description": "Profile Service"
    }
  ],
  "paths": {
    "/api/profiles": {
      "get": {
        "tags": ["user-profile-controller"],
        "operationId": "getAllUserProfiles",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserProfileResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["user-profile-controller"],
        "operationId": "createUserProfile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserProfileRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/profiles/{userId}": {
      "get": {
        "tags": ["user-profile-controller"],
        "operationId": "getUserProfile",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserProfileRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "minLength": 1
          },
          "fullName": {
            "type": "string",
            "minLength": 1
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string",
            "minLength": 1
          },
          "profilePictureUrl": {
            "type": "string"
          }
        },
        "required": ["dateOfBirth", "fullName", "gender", "userId"]
      },
      "UserProfileResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string"
          },
          "profilePictureUrl": {
            "type": "string"
          },
          "exp": {
            "type": "integer",
            "format": "int64"
          },
          "level": {
            "type": "integer",
            "format": "int32"
          },
          "currentStreak": {
            "type": "integer",
            "format": "int32"
          },
          "longestStreak": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
  }
}
