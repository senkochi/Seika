{
  "openapi": "3.1.0",
  "info": {
    "title": "Marketplace Service API",
    "description": "Product catalog and order management service for Seika platform",
    "contact": {
      "name": "Seika Development Team",
      "url": "https://seika.dev"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "API Gateway"
    },
    {
      "url": "http://marketplace-service:8085",
      "description": "Marketplace Service"
    }
  ],
  "paths": {
    "/api/marketplace/orders": {
      "post": {
        "tags": ["order-controller"],
        "operationId": "createOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/marketplace/products": {
      "get": {
        "tags": ["product-controller"],
        "operationId": "getProducts",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/marketplace/inventory/my-items": {
      "get": {
        "tags": ["inventory-controller"],
        "operationId": "getMyInventory",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateOrderItemRequest": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "productType": {
            "type": "string"
          },
          "referenceId": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "unitPrice": {
            "type": "number"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "sellerUserId": {
            "type": "string"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemRequest"
            },
            "minItems": 1
          }
        },
        "required": ["items", "userId"]
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "totalAmount": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": ["FLASHCARD", "QUIZ"]
          },
          "referenceId": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "sellerUserId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
