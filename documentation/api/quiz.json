{
  "openapi": "3.1.0",
  "info": {
    "title": "Quiz Service API",
    "description": "Quiz and question management service for Seika platform",
    "contact": {
      "name": "Seika Development Team",
      "url": "https://seika.dev"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "API Gateway"
    },
    {
      "url": "http://quiz-service:8087",
      "description": "Quiz Service"
    }
  ],
  "paths": {
    "/api/quiz": {
      "get": {
        "tags": ["quiz-controller"],
        "operationId": "getQuizzes",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListQuizResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["quiz-controller"],
        "operationId": "createQuiz",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/FillInBlankRequest"
                  },
                  {
                    "$ref": "#/components/schemas/MatchingRequest"
                  },
                  {
                    "$ref": "#/components/schemas/McqRequest"
                  },
                  {
                    "$ref": "#/components/schemas/ReorderRequest"
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseQuizResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/reorder": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockReorder",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/quizzes": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getAllMockQuizzes",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListBaseQuiz"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/quizzes/{id}": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockQuizById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/quizzes/type/{type}": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockQuizzesByType",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/multiple-choice": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockMultipleChoice",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/matching": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockMatching",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dev/mock/fill-in-blank": {
      "get": {
        "tags": ["mock-data-controller"],
        "operationId": "getMockFillInBlank",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/quiz/{id}": {
      "get": {
        "tags": ["quiz-controller"],
        "operationId": "getQuiz",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseQuizResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FillInBlankRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/QuizCreateRequest"
          },
          {
            "type": "object",
            "properties": {
              "acceptedAnswers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "MatchingRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/QuizCreateRequest"
          },
          {
            "type": "object",
            "properties": {
              "matchingPairs": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "McqRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/QuizCreateRequest"
          },
          {
            "type": "object",
            "properties": {
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "correctOptionIndex": {
                "type": "integer",
                "format": "int32"
              }
            }
          }
        ]
      },
      "QuizCreateRequest": {
        "type": "object",
        "discriminator": {
          "propertyName": "type"
        },
        "properties": {
          "questionText": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "MULTIPLE_CHOICE",
              "REORDER",
              "MATCHING",
              "FILL_IN_THE_BLANK"
            ]
          }
        }
      },
      "ReorderRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/QuizCreateRequest"
          },
          {
            "type": "object",
            "properties": {
              "correctOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "ApiResponseQuizResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/QuizResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "QuizResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "questionText": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "MULTIPLE_CHOICE",
              "REORDER",
              "MATCHING",
              "FILL_IN_THE_BLANK"
            ]
          }
        }
      },
      "ApiResponseObject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {},
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiResponseListBaseQuiz": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/FillInBlankQuiz"
                },
                {
                  "$ref": "#/components/schemas/MatchingQuiz"
                },
                {
                  "$ref": "#/components/schemas/MultipleChoiceQuiz"
                },
                {
                  "$ref": "#/components/schemas/ReorderQuiz"
                }
              ]
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BaseQuiz": {
        "type": "object",
        "discriminator": {
          "propertyName": "type"
        },
        "properties": {
          "id": {
            "type": "string"
          },
          "questionText": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "MULTIPLE_CHOICE",
              "REORDER",
              "MATCHING",
              "FILL_IN_THE_BLANK"
            ]
          }
        }
      },
      "FillInBlankQuiz": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseQuiz"
          },
          {
            "type": "object",
            "properties": {
              "acceptedAnswers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "MatchingQuiz": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseQuiz"
          },
          {
            "type": "object",
            "properties": {
              "matchingPairs": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "MultipleChoiceQuiz": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseQuiz"
          },
          {
            "type": "object",
            "properties": {
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "correctOptionIndex": {
                "type": "integer",
                "format": "int32"
              }
            }
          }
        ]
      },
      "ReorderQuiz": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseQuiz"
          },
          {
            "type": "object",
            "properties": {
              "correctOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "ApiResponseListQuizResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuizResponse"
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
